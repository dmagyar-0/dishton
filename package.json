{
  "name": "dishton",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm test:unit && pnpm test:components",
    "test:unit": "vitest run src/domain",
    "test:components": "vitest run src/ui src/lib",
    "test:coverage": "vitest run --coverage",
    "test:edge": "deno test -A --config supabase/functions/deno.json supabase/functions",
    "test:db": "deno run -A supabase/tests/run.ts",
    "test:e2e": "playwright test",
    "eval:nim": "deno run --env-file=.env --config eval/nim/deno.json --allow-net --allow-read --allow-env --allow-write eval/nim/run.ts eval/nim/urls.txt",
    "prompt:show": "deno run --config eval/nim/deno.json --allow-net --allow-read --allow-env eval/nim/show-prompt.ts",
    "test:eval": "deno test --config eval/nim/deno.json -A eval/nim",
    "db:reset": "supabase db reset",
    "fn:serve": "supabase functions serve --no-verify-jwt",
    "fn:deploy": "supabase functions deploy"
  },
  "dependencies": {
    "@hookform/resolvers": "^3",
    "@noble/hashes": "^1.5.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@sentry/react": "^8",
    "@supabase/supabase-js": "^2",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "convert-units": "^2",
    "date-fns": "^4",
    "i18next": "^24",
    "i18next-http-backend": "^3",
    "lucide-react": "^0.460",
    "motion": "^12",
    "nanoid": "^5",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7",
    "react-i18next": "^15",
    "tailwind-merge": "^2",
    "zod": "^3",
    "zustand": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@playwright/test": "^1.48",
    "@tailwindcss/vite": "^4",
    "@tanstack/router-vite-plugin": "^1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^2",
    "fast-check": "^3",
    "husky": "^9",
    "jsdom": "^25",
    "lint-staged": "^15",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5.6",
    "vite": "^6",
    "vite-plugin-pwa": "^0.20",
    "vitest": "^2",
    "workbox-window": "^7.4.0"
  }
}
