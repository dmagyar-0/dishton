# SPA (public — inlined into the bundle by Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_FEATURE_GOOGLE_AUTH=false
VITE_FEATURE_TRANSLATION_CACHE=true
VITE_SENTRY_DSN_FRONTEND=

# Edge Function secrets — set via `supabase secrets set` or the Dashboard.
# Listed here only as placeholders; do not put real values in this file.
ANTHROPIC_API_KEY=
# Optional per-lane overrides. Defaults: text=claude-haiku-4-5,
# vision=claude-sonnet-4-6 (eval round 2 — Haiku fails multi-column photos).
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MODEL_VISION=claude-sonnet-4-6
IG_OEMBED_TOKEN=
LOG_DRAIN_TOKEN=
AI_MOCK_MODE=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CI / deploy (GitHub Actions secrets)
SUPABASE_ACCESS_TOKEN=
# `supabase link` target, one per remote environment. deploy.yml reads
# SUPABASE_PROJECT_REF_PROD; the preview pipeline reads SUPABASE_PROJECT_REF_PREVIEW.
SUPABASE_PROJECT_REF_PROD=
SUPABASE_PROJECT_REF_PREVIEW=
SENTRY_DSN_FUNCTIONS=
# Source-map upload to Sentry during the deploy build. Optional: when absent
# the upload step is skipped (build still succeeds).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
