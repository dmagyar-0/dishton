# SPA (public — inlined into the bundle by Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_FEATURE_GOOGLE_AUTH=false
VITE_FEATURE_INSTAGRAM_IMPORT=true
VITE_FEATURE_PHOTO_IMPORT=true
VITE_FEATURE_TRANSLATION_CACHE=true
VITE_SENTRY_DSN_FRONTEND=

# Edge Function secrets — set via `supabase secrets set` or the Dashboard.
# Listed here only as placeholders; do not put real values in this file.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-haiku-4-5 (vision-capable).
ANTHROPIC_MODEL=claude-haiku-4-5
IG_OEMBED_TOKEN=
LOG_DRAIN_TOKEN=
AI_MOCK_MODE=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CI / deploy (GitHub Actions secrets)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SENTRY_DSN_FUNCTIONS=
SENTRY_AUTH_TOKEN=
LOGTAIL_TOKEN=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
INSTAGRAM_OEMBED_TOKEN=
